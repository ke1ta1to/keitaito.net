# データベース接続用のURL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres?schema=public"

# Redis接続用のURL
REDIS_URL="redis://localhost:6379"

# サーバーポート
PORT=3010

# JWTシークレットキー
JWT_SECRET="super-secret-long-and-complex-string"

# bcrypt の計算コスト（4〜31）
BCRYPT_COST=12

# パスワード用ペッパー（推測困難な文字列を設定してください）
PASSWORD_PEPPER="change-me-to-a-secure-value"
